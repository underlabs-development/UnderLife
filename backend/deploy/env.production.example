# Copy to /opt/UnderLife/backend/.env and fill in real values.
# (settings.py auto-loads this file: DJANGO_READ_DOT_ENV_FILE defaults to True)

# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_DEBUG=False
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM
DJANGO_ALLOWED_HOSTS=api-local-os.underlabs.it,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://api-local-os.underlabs.it,https://local-os.underlabs.it
CORS_ALLOWED_ORIGINS=https://local-os.underlabs.it
FRONTEND_URL=https://local-os.underlabs.it

# ── Database (local Postgres) ─────────────────────────────────────────────────
POSTGRES_DB=underfinance
POSTGRES_USER=underfinance
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── Email (optional; console backend if unset) ────────────────────────────────
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@your-domain

# ── Bank sync (Enable Banking) ────────────────────────────────────────────────
BANKSYNC_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
ENABLEBANKING_BASE_URL=https://api.enablebanking.com
ENABLEBANKING_REDIRECT_URL=https://api-local-os.underlabs.it/api/banksync/callback
ENABLEBANKING_APP_ID=your-app-id
ENABLEBANKING_PRIVATE_KEY_PATH=/opt/UnderLife/backend/secrets/your-app-id.pem

# ── Local AI (optional) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M
